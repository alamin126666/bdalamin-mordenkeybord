<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/font_chip_height"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_4"
    android:layout_marginStart="@dimen/font_chip_margin"
    android:layout_marginEnd="@dimen/font_chip_margin">

    <TextView
        android:id="@+id/tv_font_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/font_chip_text_size"
        android:textColor="@color/font_chip_text_inactive"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@drawable/bg_font_chip"
        android:minWidth="@dimen/font_chip_min_width"
        android:gravity="center"
        android:singleLine="true" />

</LinearLayout>
